# Copy to .env and fill in. ALL are optional for a basic demo —
# the bot runs with fallbacks if these are missing.

# Twilio (needed to fetch voice notes + send reminders; not needed for text demo)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Voice transcription. Bhashini (free, govt, best for Marathi) is preferred if set;
# otherwise Whisper is used. Register at bhashini.gov.in.
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_INFERENCE_URL=
BHASHINI_ASR_SERVICE_ID=
OPENAI_API_KEY=

# Live weather alerts. Without this, a canned "rain tomorrow" alert is used.
OPENWEATHER_API_KEY=

# Claude for warm Marathi phrasing. Without this, raw messages are sent.
ANTHROPIC_API_KEY=

PORT=5000
